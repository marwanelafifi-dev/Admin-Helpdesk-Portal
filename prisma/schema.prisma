generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  super_admin
  admin
  manager
  employee  // @si-ware.com Google Workspace users
  external  // credential-based external users
}

enum RequestStatus {
  draft
  new
  on_hold
  in_customs
  in_transit
  delivered
  completed
  cancelled
  pending_assignment
  assigned
  awaiting_input
  resolved
  closed
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?   // null for Google users, bcrypt hash for external users

  // Hybrid RBAC: base role + optional per-user overrides
  role          UserRole  @default(employee)
  sessionVersion Int      @default(0)
  /// `customPermissions` stores an array of permission overrides for the user.
  /// Expected shape: [{ permission: string, allowed: boolean }, ...]
  customPermissions Json?
  requests      Request[]
  notifications Notification[]
  conversations Conversation[]

  accounts      Account[]
  sessions      Session[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([role])
}

model Request {
  id             String        @id @default(cuid())
  module         String
  title          String
  status         RequestStatus @default(new)
  payload        Json
  statusHistory  Json?

  requesterId    String
  requester      User          @relation(fields: [requesterId], references: [id], onDelete: Restrict)

  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([module, status])
  @@index([requesterId, createdAt])
}

// NextAuth models
model Account {
  id                 String   @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?
  oauth_token_secret String?
  oauth_token        String?

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Notifications ────────────────────────────────────────────────────────

enum NotificationType {
  request_submitted
  request_approved
  request_rejected
  request_updated
  comment_added
  admin_alert
}

model Notification {
  id          String            @id @default(cuid())
  type        NotificationType
  title       String
  message     String
  read        Boolean           @default(false)
  
  userId      String
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  requestId   String?
  link        String?           // Link to the request page
  
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  
  @@index([userId, read, createdAt])
  @@index([requestId])
}

// ─── Role Permissions ─────────────────────────────────────────────────────

model RolePermission {
  id          String   @id @default(cuid())
  role        UserRole
  permission  String   // e.g., "view_requests", "create_requests", "approve_requests"
  allowed     Boolean  @default(true)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@unique([role, permission])
}

// ─── AI Conversations ─────────────────────────────────────────────────────────
//
// Stores the full message history for each AI Assistant conversation.
// `messages` is a JSON array of { role, content } objects — the same shape
// the client sends in `history` and the orchestrator passes to Groq.
//
// Connection-pooling note:
//   The singleton getPrisma() helper reuses one PrismaClient across hot-reloads
//   in development and across warm serverless invocations in production.
//   This is the correct pattern for PostgreSQL + Prisma in Next.js.

model Conversation {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String?
  messages  Json     @default("[]")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, updatedAt])
}

// ─── Audit Logs ───────────────────────────────────────────────────────────

model AuditLog {
  id          String   @id @default(cuid())
  action      String   // "create", "update", "delete", "approve", etc.
  module      String   // "requests", "users", "roles", etc.
  recordId    String
  userId      String
  changes     Json?    // old and new values
  metadata    Json?    // additional context
  
  createdAt   DateTime @default(now())
  
  @@index([module, recordId])
  @@index([userId, createdAt])
  @@index([userId, action, createdAt])
}
