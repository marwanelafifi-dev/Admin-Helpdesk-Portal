generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  super_admin
  admin
  manager
  employee  // @si-ware.com Google Workspace users
  external  // credential-based external users
}

enum RequestStatus {
  draft
  new
  on_hold
  in_customs
  in_transit
  delivered
  completed
  cancelled
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?   // null for Google users, bcrypt hash for external users

  role          UserRole  @default(employee)
  requests      Request[]

  accounts      Account[]
  sessions      Session[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Request {
  id             String        @id @default(cuid())
  module         String
  title          String
  status         RequestStatus @default(new)
  payload        Json
  statusHistory  Json?

  requesterId    String
  requester      User          @relation(fields: [requesterId], references: [id], onDelete: Restrict)

  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([module, status])
  @@index([requesterId, createdAt])
}

// NextAuth models
model Account {
  id                 String   @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?
  oauth_token_secret String?
  oauth_token        String?

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
