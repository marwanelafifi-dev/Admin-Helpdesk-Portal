# Local development environment variables for NextAuth and Google OAuth
# Copy this file to .env.local or .env and fill in the actual values.

# NextAuth base URL
NEXTAUTH_URL=http://localhost:3003

# NextAuth secret used for signing cookies and session tokens
NEXTAUTH_SECRET=replace_with_a_secure_random_string

# Google OAuth credentials
AUTH_GOOGLE_ID=your_google_client_id.apps.googleusercontent.com
AUTH_GOOGLE_SECRET=your_google_client_secret

# Optional alternate variable names supported by auth.ts
# GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your_google_client_secret
# AUTH_SECRET=replace_with_a_secure_random_string

# Optional local workaround for corporate SSL inspection / self-signed cert chains
# Use only for local development when Google auth fails because of certificate validation.
# DISABLE_TLS_CERT_CHECK=true
