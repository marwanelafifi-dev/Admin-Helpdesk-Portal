# Copy this file to `.env` for local Docker usage.

# Postgres service (docker-compose)
POSTGRES_DB=arp
POSTGRES_USER=arp_user
POSTGRES_PASSWORD=arp_password

# Next.js container -> Postgres container connection (service name = db)
# Prisma note: keep `schema=public`. You can optionally add `connection_limit=5` in production.
DATABASE_URL="postgresql://arp_user:arp_password@db:5432/arp?schema=public"

# NextAuth/Auth.js
NEXTAUTH_URL="http://localhost:3003"
NEXTAUTH_SECRET="replace-with-a-long-random-secret"

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_ALLOWED_DOMAIN="mycompany.com"
MAINTENANCE_MODE="false"

# Email (SMTP — use Gmail App Password or any SMTP relay)
# For Google Workspace: host=smtp.gmail.com, port=587, user=your@domain.com, pass=app-password
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="ARP Notifications <noreply@si-ware.com>"

# Admin notification emails (comma-separated list for new request alerts)
NOTIFICATION_EMAIL_ADMINS="admin1@company.com,admin2@company.com"

# --- Docker Compose (production-style stack: see docker-compose.yml) ---
# Use the same DATABASE_URL as above (host name `db` inside the compose network).
# Apply migrations before or after first boot (from host with DB reachable):
#   npx prisma migrate deploy
